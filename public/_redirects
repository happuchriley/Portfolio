# SEO & static files — must be listed before the SPA fallback so crawlers
# receive real XML/text instead of index.html.
/sitemap.xml           /sitemap.xml           200
/robots.txt            /robots.txt            200
/manifest.webmanifest  /manifest.webmanifest  200
/browserconfig.xml     /browserconfig.xml     200

# Netlify SPA fallback for client-side routes.
/*                     /index.html            200
